// ───────────────────────────────────────────────────────────────────────────
const (
	// ArkAPIKey 作为 Bearer Token 使用。
	ArkAPIKey = "PLEASE_FILL_ARK_API_KEY" // TODO: 填入真实 API Key

	// ArkModel 模型 / 接入点 ID(如 doubao 系列的 endpoint id 或模型名)。
	ArkModel = "PLEASE_FILL_ARK_MODEL_OR_ENDPOINT_ID" // TODO: 填入真实接入点/模型

	// ArkEndpoint Chat Completions 接口地址(如地域不同请自行修改)。
	ArkEndpoint = "https://ark.cn-beijing.volces.com/api/v3/chat/completions"
)

// ───────────────────────────────────────────────────────────────────────────
// 服务端 / 中继
// ───────────────────────────────────────────────────────────────────────────
const (
	// ListenAddr 后端 WebSocket 中继监听地址。
	ListenAddr = "0.0.0.0:8765"

	// ClientWSPath 前端扩展连接后端的 WebSocket 路径。
	ClientWSPath = "/ws"

	// HealthPath 健康检查路径。
	HealthPath = "/healthz"
)

// ───────────────────────────────────────────────────────────────────────────
// 翻译目标语言 & 分句
// ───────────────────────────────────────────────────────────────────────────
const (
	// TargetLanguage 目标语言,本项目固定翻译为中文。
	TargetLanguage = "中文"
)

// TranslateConfig 控制方舟(Ark)翻译的行为。
type TranslateConfig struct {
	// ContextWindow 翻译时携带的上下文(最近 N 段「原文 => 译文」),
	// 用于保持术语、人名与语气一致。
	ContextWindow int

	// Timeout 单次翻译请求的超时时间。
	Timeout time.Duration

	// Temperature 采样温度,低温更稳定、更贴近直译。
	Temperature float64

	// MaxTokens 译文最大长度;0 表示不显式限制。
	MaxTokens int

	// PartialPreview 开启「边说边译」:对说话中(partial)的句子也实时翻译,
	// 句子定稿后再用带上下文的正式译文原地覆盖。关闭则只翻译定稿句子。
	PartialPreview bool

	// PartialMinChars 触发一次 partial 重译所需的最小原文增量(按字符/rune 计):
	// 原文相比上次送译至少多出这么多字才再次翻译,避免逐字刷接口。
	PartialMinChars int

	// PartialMinInterval 同一句两次 partial 翻译之间的最小时间间隔。
	PartialMinInterval time.Duration
}

// Translate 当前生效的翻译配置(写死的默认值)。
var Translate = TranslateConfig{
	ContextWindow:      3, // 上下文从 5 降到 3:更短的提示词 -> 更快返回译文(略微牺牲长距一致性)
	Timeout:            20 * time.Second,
	Temperature:        0.3,
	MaxTokens:          256, // 单句译文足够;上限收紧让生成更快收尾
	PartialPreview:     true,
	PartialMinChars:    2,                      // 每多 2 字就送译,边说边译跟得更紧
	PartialMinInterval: 140 * time.Millisecond, // partial 译文刷新节流间隔(缩短:正在说的内容跟得更紧)
}

// ───────────────────────────────────────────────────────────────────────────
// 术语表 / 领域提示词(里程碑 8)
// ───────────────────────────────────────────────────────────────────────────

// PromptConfig 定制翻译与复审的「领域背景」与「术语对照」。
// 两者都会注入到翻译 / 复审的系统提示词中,用来稳定专有名词与译法一致性。
type PromptConfig struct {
	// Domain 领域 / 场景背景描述(自由文本)。例如:
	//   "一场关于机器学习与大语言模型的技术分享,讲者会频繁使用深度学习术语"。
	// 留空表示不附加领域背景。
	Domain string

	// Glossary 术语对照表:原文词条 => 指定译法。命中时必须采用指定译法,
	// 用于锁定人名、产品名、专业术语的统一翻译。留空表示不启用术语表。
	Glossary map[string]string
}

// Prompt 当前生效的术语表 / 领域提示词(默认均为空,不改变既有翻译行为)。
// 按需在此填入领域背景与术语,例如:
//
//	var Prompt = PromptConfig{
//	    Domain: "一场关于机器学习的技术分享",
//	    Glossary: map[string]string{
//	        "transformer": "Transformer 架构",
//	        "attention":   "注意力机制",
//	    },
//	}
var Prompt = PromptConfig{
	Domain:   "",
	Glossary: map[string]string{},
}

// ───────────────────────────────────────────────────────────────────────────
// 纠错策略(本项目核心,做成可配置)
// ───────────────────────────────────────────────────────────────────────────

// CorrectionConfig 定义两层纠错能力的开关与参数。
type CorrectionConfig struct {
	// EnableASRRevision 开启「ASR 修订重译」:当 ASR 对已 final 的早先片段
	// 返回修订时,把该 segment 标记为 dirty 并重新翻译、原地替换。
	EnableASRRevision bool

	// EnablePeriodicReview 开启「周期性 LLM 复审」:带最近 N 段上下文,
	// 让 LLM 用后文澄清的信息校正早先译文。
	EnablePeriodicReview bool

	// ReviewContextWindow 复审滑动窗口大小(最近 N 段「原文+译文」)。
	ReviewContextWindow int

	// ReviewInterval 周期性复审的时间间隔(到句子边界或每隔该时间触发一次)。
	ReviewInterval time.Duration

	// OverwriteOnlyIfMoreConfident 仅当复审「确信改得更准」时才覆盖旧译文。
	// 开启后,复审返回的每句修订都带一个 confidence(0~1),只有
	// confidence >= ReviewMinConfidence 且模型确实标记 changed 的句子才会被替换,
	// 从而避免「把本来正确的句子改成另一种同义说法」的过度纠错(那只会让字幕闪烁)。
	OverwriteOnlyIfMoreConfident bool

	// ReviewMinConfidence 应用一条复审修订所需的最低置信度(0~1)。
	// 仅在 OverwriteOnlyIfMoreConfident=true 时生效。调高=更保守,调低=更激进。
	ReviewMinConfidence float64
}

// Correction 当前生效的纠错配置(写死的默认值)。
var Correction = CorrectionConfig{
	EnableASRRevision:            true,
	EnablePeriodicReview:         true,
	ReviewContextWindow:          5,
	ReviewInterval:               1200 * time.Millisecond, // 定时兜底降到 1.2s;主路径是「每句定稿即触发复审」,两者叠加让修订尽快闪现
	OverwriteOnlyIfMoreConfident: true,
	ReviewMinConfidence:          0.6,
}

// ───────────────────────────────────────────────────────────────────────────
// 连接 / 重连 / 节流
// ───────────────────────────────────────────────────────────────────────────

// ReconnectConfig 断线自动重连(指数退避)参数。
type ReconnectConfig struct {
	InitialBackoff time.Duration // 初始退避
	MaxBackoff     time.Duration // 最大退避
	Multiplier     float64       // 退避倍数
	MaxRetries     int           // 最大重试次数,0 表示无限重试
}

// Reconnect 当前生效的重连配置。
var Reconnect = ReconnectConfig{
	InitialBackoff: 500 * time.Millisecond,
	MaxBackoff:     15 * time.Second,
	Multiplier:     2.0,
	MaxRetries:     0,
}

// ───────────────────────────────────────────────────────────────────────────
