// ───────────────────────────────────────────────────────────────────────────
const (
	AudioSampleRate = 16000 // 16kHz
	AudioBitDepth   = 16    // 16bit
	AudioChannels   = 1     // 单声道
	AudioChunkMs    = 100   // 约 100ms 一片
)
