{
  "manifest_version": 3,
  "name": "AI 同声传译助手(火山引擎版)",
  "version": "0.2.2",
  "description": "实时把标签页中的外语音频翻译为中文滚动字幕(可选 TTS),具备自动纠错能力。",
  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "ws://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "同声传译(点击或按 Alt+Shift+S 开始/停止)"
  },
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "开始/停止同声传译"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["overlay.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["audio-worklet.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
